# ===== Servidor =====
PORT=3333
# URL publica usada para montar a URL das fotos enviadas.
# No emulador Android use 10.0.2.2; no dispositivo fisico use o IP da sua maquina.
PUBLIC_URL=http://localhost:3333

# ===== Banco MySQL =====
DB_HOST=localhost
