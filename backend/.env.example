# ===== Servidor =====
PORT=3333
# URL publica usada para montar a URL das fotos enviadas.
# No emulador Android use 10.0.2.2; no dispositivo fisico use o IP da sua maquina.
PUBLIC_URL=http://localhost:3333

# ===== Banco MySQL =====
# Se usar o docker-compose.yml da raiz, os valores ja batem (porta 3307).
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=root
DB_PASSWORD=root
DB_NAME=teste_mobile

# ===== Autenticacao =====
JWT_SECRET=troque-este-segredo-em-producao
JWT_EXPIRES_IN=7d
